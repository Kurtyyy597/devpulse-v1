{
  "extends": "../tsconfig.base.json",

  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "rootDir": "..",
    "outDir": "./dist",

    "paths": {
      "@shared/*": ["../shared/*"]
    },

    "lib": ["ES2020"],
    "types": ["node"],

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,

    "sourceMap": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },

  "include": [
    "src",
    "../shared/types",
    "../shared/const",
    "../shared/data",
    "../shared/helper-functions",
    "../shared/errors"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}