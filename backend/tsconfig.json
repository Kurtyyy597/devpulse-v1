{
  "extends": "../tsconfig.base.json",

  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "rootDir": "..",
    "outDir": "./dist",

    "lib": ["ES2020"],
    "types": ["node"],

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,

    "sourceMap": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },

  "include": [
  "src",
  "../shared"
],

  "exclude": [
    "node_modules",
    "dist"
  ]
}